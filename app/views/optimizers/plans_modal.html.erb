<%= turbo_frame_tag "modal" do %>
  <div class="modal-backdrop" data-controller="modal" data-action="click->modal#closeOutside">
    <div class="modal-container">
      <div id="modal-content" class="optimizer-plan-select-container">
        <div class="modal-header">
          <h2 class="modal-title optimizer-plan-select-title">Select a Plan</h2>
        </div>

        <div class="optimizer-plan-grid">
          <% @plans.each do |plan| %>
            <%= button_to optimizer_select_plan_path,
                params: { plan_id: plan.id },
                data: { turbo_stream: true },
                class: "optimizer-plan-select-card" do %>
              <% if plan.subject.image_url.present? %>
                <%= image_tag plan.subject.image_url, class: "optimizer-plan-select-icon" %>
              <% end %>
              <div class="optimizer-plan-select-info">
                <span class="optimizer-plan-select-name"><%= plan.subject.name %></span>
                <span class="optimizer-plan-select-type"><%= plan.subject_type %></span>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>
