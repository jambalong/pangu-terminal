<div class="forte-column <%= 'inherent-node' if config[:inherent] %>">
  <label class="node-label">
    <%= f.check_box "#{config[:key]}_node_2", { class: "peer hidden" }, 1, 0 %>
    <% if config[:inherent] %>
      <div class="node-diamond-top node-2">
        <% if config[:inherent_2_icon] %>
          <div class="node-icon-bg" style="background-image: url('<%= asset_path(config[:inherent_2_icon]) %>')"></div>
        <% else %>
          <span>✱</span>
        <% end %>
      </div>
    <% else %>
      <div class="node-circle node-2">
        <% if config[:stat_icon] %>
          <div class="node-icon-bg" style="background-image: url('<%= asset_path(config[:stat_icon]) %>')"></div>
        <% else %>
          <span>✱</span>
        <% end %>
      </div>
    <% end %>
  </label>

  <div class="node-connector"></div>

  <label class="node-label">
    <%= f.check_box "#{config[:key]}_node_1", { class: "peer hidden" }, 1, 0 %>
    <% if config[:inherent] %>
      <div class="node-diamond-top node-1">
        <% if config[:inherent_1_icon] %>
          <div class="node-icon-bg" style="background-image: url('<%= asset_path(config[:inherent_1_icon]) %>')"></div>
        <% else %>
          <span>✱</span>
        <% end %>
      </div>
    <% else %>
      <div class="node-circle node-1">
        <% if config[:stat_icon] %>
          <div class="node-icon-bg" style="background-image: url('<%= asset_path(config[:stat_icon]) %>')"></div>
        <% else %>
          <span>✱</span>
        <% end %>
      </div>
    <% end %>
  </label>

  <div class="node-connector"></div>

  <div class="node-diamond">
    <% if config[:skill_icon] %>
      <div class="node-icon-bg" style="background-image: url('<%= asset_path(config[:skill_icon]) %>')"></div>
    <% else %>
      <span>✱</span>
    <% end %>
  </div>

  <%# Skill Level Indicators (Current → Target) %>
  <div class="skill-level-text">
    <span id="<%= config[:key] %>_current_val">
      <%= f.object.send("#{config[:key]}_current") %>
    </span>
    <span>→</span>
    <span id="<%= config[:key] %>_target_val">
      <%= f.object.send("#{config[:key]}_target") %>
    </span>
  </div>

  <%# Slider Group Container %>
  <div class="flex flex-col gap-1 w-full items-center">
    <%# Current Slider %>
    <div data-controller="slider" class="w-full">
      <%= f.range_field "#{config[:key]}_current",
                    min: 1, max: 10,
                    class: "skill-slider",
                    data: {
                      slider_target: "input",
                      action: "input->slider#update",
                    } %>
      <span
        class="hidden"
        data-slider-target="label"
        data-link-id="<%= config[:key] %>_current_val"
      ></span>
    </div>

    <%# Target Slider %>
    <div data-controller="slider" class="w-full">
      <%= f.range_field "#{config[:key]}_target",
                    min: 1, max: 10,
                    class: "skill-slider",
                    data: {
                      slider_target: "input",
                      action: "input->slider#update",
                    } %>
      <span
        class="hidden"
        data-slider-target="label"
        data-link-id="<%= config[:key] %>_target_val"
      ></span>
    </div>
  </div>
</div>
