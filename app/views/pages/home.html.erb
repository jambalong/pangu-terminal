<%= turbo_frame_tag "main_content" do %>
  <div class="landing-wrapper">

    <!-- Hero Section -->
    <section class="hero-section">
      <div class="hero-content">
        <div class="system-status">
          <span class="status-dot"></span>
          SYSTEM ONLINE :: v1.0.0
        </div>

        <h1 class="hero-title">
          PANGU<span class="text-mauve">TERMINAL</span>
        </h1>

        <p class="hero-subtitle">
          The tactical resource planner for Wuthering Waves.
          <br>
          <br>
          <span class="feature-tick">></span> Plan for resonators & weapons.
          <br>
          <span class="feature-tick">></span> Track materials in inventory.
          <br>
          <span class="feature-tick">></span> Optimize Waveplate farming runs.
          <br>
          <span class="feature-tick">></span> Get AI farming recommendations.
          <br>
          <span class="feature-tick">></span> Sync across your devices.
          <br>
          <span class="feature-tick">></span> <strong>And more upcoming features!</strong>
        </p>

        <div class="hero-actions">
          <%= link_to plans_path,
              data: { turbo_frame: "main_content", turbo_action: "advance" },
              class: "btn-terminal-primary" do %>
            <span>></span> INITIALIZE_PLANNER
          <% end %>

          <%= link_to inventory_items_path,
              data: { turbo_frame: "main_content", turbo: false },
              class: "btn-terminal-outline" do %>
            <span>$</span> CHECK_INVENTORY
          <% end %>
        </div>
      </div>

      <!-- Terminal Window Mockup -->
      <div class="terminal-window">
        <div class="window-header">
          <div class="window-buttons">
            <span class="bg-red"></span>
            <span class="bg-yellow"></span>
            <span class="bg-green"></span>
          </div>
          <div class="window-title">ascension_planner.app</div>
        </div>

        <div class="window-body">
          <!-- Mock Plan Header -->
          <div class="mock-header">
            <div class="mock-title">
              <div class="mock-title-left">
                <%= image_tag "/images/resonators/augusta.png", alt: "Augusta", class: "mock-portrait" %>
                Augusta
              </div>
              <span class="mock-stars">★★★★★</span>
            </div>
            <div class="mock-subtitle">CONFIGURE RESONATOR PLAN</div>
          </div>

          <!-- Mock Stats -->
          <div class="mock-stats-row">
            <div class="mock-stat-box">
              <span class="label">LEVEL</span>
              <div class="value-row">
                1 <span class="arrow">→</span> <span class="highlight">90</span>
              </div>
            </div>
            <div class="mock-stat-box">
              <span class="label">ASCENSION</span>
              <div class="value-row">
                0 <span class="arrow">→</span> <span class="highlight">6</span>
              </div>
            </div>
          </div>

          <!-- Mock Forte Node Tree -->
          <div class="mock-nodes-container">
            <!-- Column 1: Normal Attack -->
            <div class="mock-node-col">
              <div class="mock-circle active">✱</div>
              <div class="mock-line active"></div>
              <div class="mock-circle active">✱</div>
              <div class="mock-line active"></div>
              <div class="mock-diamond active">✱</div>
              <span>8 → 10</span>
              <div class="mock-slider-track">
                <div class="mock-slider-fill" style="width: 80%;"></div>
                <div class="mock-slider-thumb" style="left: 80%;"></div>
              </div>
            </div>

            <!-- Column 2: Resonance Skill -->
            <div class="mock-node-col">
              <div class="mock-circle">✱</div>
              <div class="mock-line"></div>
              <div class="mock-circle active">✱</div>
              <div class="mock-line active"></div>
              <div class="mock-diamond active">✱</div>
              <span>6 → 10</span>
              <div class="mock-slider-track">
                <div class="mock-slider-fill" style="width: 60%;"></div>
                <div class="mock-slider-thumb" style="left: 60%;"></div>
              </div>
            </div>

            <!-- Column 3: Liberation — all diamonds -->
            <div class="mock-node-col mobile-hide">
              <div class="mock-diamond active">✱</div>
              <div class="mock-line active"></div>
              <div class="mock-diamond active">✱</div>
              <div class="mock-line active"></div>
              <div class="mock-diamond active">✱</div>
              <span>10 → 10</span>
              <div class="mock-slider-track">
                <div class="mock-slider-fill" style="width: 100%;"></div>
                <div class="mock-slider-thumb" style="left: 95%;"></div>
              </div>
            </div>

            <!-- Column 4: Intro Skill -->
            <div class="mock-node-col">
              <div class="mock-circle">✱</div>
              <div class="mock-line"></div>
              <div class="mock-circle active">✱</div>
              <div class="mock-line active"></div>
              <div class="mock-diamond active">✱</div>
              <span>5 → 10</span>
              <div class="mock-slider-track">
                <div class="mock-slider-fill" style="width: 50%;"></div>
                <div class="mock-slider-thumb" style="left: 50%;"></div>
              </div>
            </div>

            <!-- Column 5: Outro Skill -->
            <div class="mock-node-col">
              <div class="mock-circle">✱</div>
              <div class="mock-line"></div>
              <div class="mock-circle">✱</div>
              <div class="mock-line"></div>
              <div class="mock-diamond active">✱</div>
              <span>2 → 10</span>
              <div class="mock-slider-track">
                <div class="mock-slider-fill" style="width: 20%;"></div>
                <div class="mock-slider-thumb" style="left: 20%;"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- How It Works Section -->
    <section class="how-it-works-section">
      <div class="section-header">
        <h2>GETTING STARTED</h2>
        <div class="divider-line"></div>
      </div>

      <div class="steps-grid">
        <div class="step-card">
          <div class="step-number">01</div>
          <h3>Create a Plan</h3>
          <p>Select a Resonator or Weapon, set your current and target levels, ascension ranks, and skill levels. The planner calculates exact material costs for the full upgrade path.</p>
        </div>

        <div class="step-card">
          <div class="step-number">02</div>
          <h3>Track Your Inventory</h3>
          <p>Enter what you own. The app reconciles your materials against every active plan, accounting for synthesis chains so you're not farming what you can already craft.</p>
        </div>

        <div class="step-card">
          <div class="step-number">03</div>
          <h3>See What to Farm</h3>
          <p>The Waveplate Optimizer turns your deficits into run estimates broken down by farming source. The Farming Advisor tells you where to go first.</p>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="features-section">
      <div class="section-header">
        <h2>FEATURES</h2>
        <div class="divider-line"></div>
      </div>

      <div class="features-grid">
        <div class="feature-card">
          <div class="card-icon">📋</div>
          <h3>Planner</h3>
          <p>Plan material requirements for any Resonator or Weapon. Track levels, ascensions, and skill upgrades all in one place.</p>
        </div>

        <div class="feature-card">
          <div class="card-icon">📦</div>
          <h3>Inventory</h3>
          <p>Track your materials with automatic synthesis calculations. See what you own vs. what you need across all your plans instantly.</p>
        </div>

        <div class="feature-card">
          <div class="card-icon">⚡</div>
          <h3>Optimizer</h3>
          <p>Calculate estimated farming runs and Waveplate costs per material deficit. Know exactly how many runs you need before you start.</p>
        </div>

        <div class="feature-card">
          <div class="card-icon">💬</div>
          <h3>Farming Advisor</h3>
          <p>Get a plain-English recommendation based on your actual deficits, synthesis chain coverage, and farming priority. Know what to run before you spend a single Waveplate.</p>
        </div>

        <div class="feature-card">
          <div class="card-icon">🔌</div>
          <h3>REST API</h3>
          <p>Access your plans, inventory, and synthesis results. Authenticate with an API key and integrate your data into any external tool or script.</p>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <% unless user_signed_in? %>
      <section class="cta-section">
        <div class="cta-card">
          <h2>Ready to optimize your progression?</h2>
          <p>Sign up to save your plans, sync your inventory, and access advanced features.</p>
          <div class="cta-actions">
            <%= link_to "Create Free Account", new_user_registration_path,
                data: { turbo: false },
                class: "btn-terminal-primary" %>
            <%= link_to "Continue as Guest", plans_path,
                data: { turbo_frame: "main_content", turbo_action: "advance" },
                class: "btn-terminal-outline" %>
          </div>
        </div>
      </section>
    <% end %>

    <!-- Footer -->
    <footer class="terminal-footer">
      <div class="footer-content">
        <p>&copy; <%= Time.now.year %> PANGU TERMINAL<br>OPEN SOURCE PROJECT</p>
        <div class="disclaimer">
          <p>This is a fan-made project and is not affiliated with Kuro Games</p>
        </div>
        <div class="footer-links">
          <a href="https://github.com/jambalong/pangu-terminal" target="_blank" rel="noopener">GITHUB</a>
          <span class="separator">|</span>
          <%= link_to "USER MANUAL", user_manual_path, data: { turbo: false } %>
        </div>
      </div>
    </footer>

  </div>
<% end %>
